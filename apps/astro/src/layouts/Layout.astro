---
import "../styles/global.css";
export interface Props {
  title?: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ?? "Movies That Feel Like"}</title>
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="brand" aria-label="Movies That Feel Like home">
        <span class="brand-mark" aria-hidden="true">MTFL</span>
        <span>Movies<br />That Feel Like</span>
      </a>
      <label class="theme-toggle">
        <input class="theme-controller" type="checkbox" value="dark" aria-label="Switch to dark theme" />
        <span class="theme-sun" aria-hidden="true">☼</span>
        <span class="theme-moon" aria-hidden="true">◐</span>
        <span class="theme-label-light" aria-hidden="true">Light</span>
        <span class="theme-label-dark" aria-hidden="true">Dark</span>
      </label>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
