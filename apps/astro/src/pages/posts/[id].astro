---
// Post detail page — single editorial surface for an Imported Vibe Post.
// Hero row (16:9 DaisyUI carousel + vibe summary sidebar) → shared tag row → 5-col
// recommendation poster grid. Clicking any hero image opens a DaisyUI modal with
// a full-screen DaisyUI carousel of the same images. See issue #4 for the spec.

import Layout from "../../layouts/Layout.astro";
import { getDb, getBuildData } from "../../lib/db";
import { env } from "cloudflare:workers";

export async function getStaticPaths() {
  const { posts } = await getBuildData(getDb(env));
  return posts.map((post) => ({ params: { id: post.redditPostId }, props: { post } }));
}

const post = Astro.props.post as Awaited<ReturnType<typeof getBuildData>>["posts"][number] | undefined;

const slideId = (i: number) => `slide${i + 1}`;
const modalSlideId = (i: number) => `modal-slide${i + 1}`;
const heroPrev = (i: number, total: number) => (i === 0 ? `#${slideId(total - 1)}` : `#${slideId(i - 1)}`);
const heroNext = (i: number, total: number) => (i === total - 1 ? `#${slideId(0)}` : `#${slideId(i + 1)}`);
const modalPrev = (i: number, total: number) => (i === 0 ? `#${modalSlideId(total - 1)}` : `#${modalSlideId(i - 1)}`);
const modalNext = (i: number, total: number) => (i === total - 1 ? `#${modalSlideId(0)}` : `#${modalSlideId(i + 1)}`);
const totalImages = post?.images.length ?? 0;
const hasHero = !!post && totalImages > 0;
const transitionToken = (id: string) => [...id].map((character) => character.codePointAt(0)!.toString(16)).join("-");
const imageTransitionName = post ? `post-image-${transitionToken(post.redditPostId)}` : undefined;
const vibeTransitionName = post ? `post-vibe-${transitionToken(post.redditPostId)}` : undefined;
const transitionNames = [imageTransitionName, post?.vibeSummary ? vibeTransitionName : undefined].filter((name): name is string => !!name);
const transitionStyles = `${transitionNames.map((name) => `::view-transition-group(${name}) { animation: none; } ::view-transition-old(${name}) { animation: mtfl-view-transition-fade-out 240ms ease both; } ::view-transition-new(${name}) { animation: mtfl-view-transition-fade-in 240ms ease both; }`).join("\n")}\n@media (prefers-reduced-motion: reduce) { ${transitionNames.map((name) => `::view-transition-old(${name}), ::view-transition-new(${name}), ::view-transition-group(${name})`).join(",\n")} { animation: none; } }`;
const tagHref = (tag: string) => `/?tag=${encodeURIComponent(tag)}`;
const redditHref = (permalink: string) => `https://reddit.com${permalink}`;

type Recommendation = NonNullable<typeof post>["recommendations"][number];
const externalHref = (rec: Recommendation): string | null => {
  if (rec.imdbId) return `https://www.imdb.com/title/${rec.imdbId}/`;
  if (rec.tmdbId) {
    const tmdbType = rec.mediaType === "tv" ? "tv" : rec.mediaType === "game" ? "game" : "movie";
    return `https://www.themoviedb.org/${tmdbType}/${rec.tmdbId}`;
  }
  return rec.externalUrl ?? null;
};
const externalLabel = (rec: Recommendation): string => {
  if (rec.imdbId) return "IMDb";
  if (rec.tmdbId) return "TMDB";
  return rec.externalUrl ? "Source" : "";
};

type ImageRole = "poster" | "backdrop";

/**
 * TMDB has a documented size ladder. Other providers, including IMDb, must
 * keep their exact supplied URL rather than receiving a fabricated variant.
 */
const responsiveImage = (url: string, role: ImageRole, sizes: string) => {
  const match = url.match(/^https:\/\/image\.tmdb\.org\/t\/p\/[^/]+(\/.*)$/);
  if (!match) return { src: url, sizes };

  const widths = role === "poster" ? [300, 500, 780] : [500, 780, 1280];
  const makeUrl = (width: number) => `https://image.tmdb.org/t/p/w${width}${match[1]}`;

  return {
    src: makeUrl(widths[1]),
    srcset: widths.map((width) => `${makeUrl(width)} ${width}w`).join(", "),
    sizes,
  };
};
---

<Layout title={post ? `${post.vibeSummary ?? "Vibe post"} — Movies That Feel Like` : "Post not found"}>
  {!post ? (
    <div class="hero min-h-64 rounded-box border border-line bg-paper transition-colors duration-240 ease-theme motion-reduce:transition-none theme-dark:border-line-dark theme-dark:bg-paper-dark">
      <div class="hero-content text-center">
        <div class="max-w-md">
          <h2 class="text-xl font-bold">Post not found</h2>
          <p class="py-4 text-quiet transition-colors duration-240 ease-theme motion-reduce:transition-none theme-dark:text-quiet-dark">
            No post with ID "{Astro.params.id}" was found in the database.
          </p>
          <a href="/" class="btn btn-primary focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark">Back to feed</a>
        </div>
      </div>
    </div>
  ) : (
    <div class="pb-24">
      {!hasHero ? (
        <div class="hero mb-12 min-h-64 rounded-box border border-line bg-paper transition-colors duration-240 ease-theme motion-reduce:transition-none theme-dark:border-line-dark theme-dark:bg-paper-dark">
          <div class="hero-content text-center">
            <div class="max-w-md">
              <h2 class="text-xl font-bold">No images</h2>
              <p class="py-4 text-quiet transition-colors duration-240 ease-theme motion-reduce:transition-none theme-dark:text-quiet-dark">
                This post has no images to display.
              </p>
            </div>
          </div>
        </div>
      ) : (
        <section class="pt-4 mb-1.5 grid grid-cols-1 items-center gap-8 lg:grid-cols-[7fr_3fr]" aria-label="Post hero">
          <div class="relative">
            <div
              class="carousel aspect-video w-full overflow-hidden bg-gallery"
              data-hero-carousel
              aria-label={`Image gallery. ${totalImages} image${totalImages === 1 ? "" : "s"}.`}
            >
              {post.images.map((img, i) => (
                <div id={slideId(i)} class="carousel-item relative w-full">
                  <button
                    type="button"
                    class="block h-full w-full focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark"
                    data-open-lightbox={i}
                    aria-label={`Open image ${i + 1} of ${totalImages} at full size`}
                  >
                    <img
                      src={img.previewUrl ?? img.sourceUrl}
                      alt={`Post image ${i + 1} of ${totalImages}`}
                      class="post-detail-hero-image h-full w-full object-cover"
                      {...(i === 0 && imageTransitionName ? { style: `view-transition-name: ${imageTransitionName};` } : {})}
                      loading={i === 0 ? "eager" : "lazy"}
                      decoding="async"
                      fetchpriority={i === 0 ? "high" : undefined}
                    />
                  </button>
                  {totalImages > 1 && (
                    <>
                      <a
                        href={heroPrev(i, totalImages)}
                        class="btn btn-circle btn-sm absolute left-4 top-1/2 -translate-y-1/2 border border-ink/20 bg-paper/90 text-ink shadow-md hover:bg-paper focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 motion-reduce:transition-none sm:btn-md theme-dark:border-ink-dark/20 theme-dark:bg-paper-dark/90 theme-dark:text-ink-dark theme-dark:hover:bg-paper-dark theme-dark:outline-red-dark"
                        aria-label="Show previous image"
                      >
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
                          <path d="m15 18-6-6 6-6" />
                        </svg>
                      </a>
                      <a
                        href={heroNext(i, totalImages)}
                        class="btn btn-circle btn-sm absolute right-4 top-1/2 -translate-y-1/2 border border-ink/20 bg-paper/90 text-ink shadow-md hover:bg-paper focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 motion-reduce:transition-none sm:btn-md theme-dark:border-ink-dark/20 theme-dark:bg-paper-dark/90 theme-dark:text-ink-dark theme-dark:hover:bg-paper-dark theme-dark:outline-red-dark"
                        aria-label="Show next image"
                      >
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
                          <path d="m9 18 6-6-6-6" />
                        </svg>
                      </a>
                    </>
                  )}
                </div>
              ))}
            </div>
            {totalImages > 1 && (
              <div class="pointer-events-none absolute inset-x-0 bottom-0 flex justify-end p-3">
                <p
                  class="rounded-full bg-ink px-3 py-1 text-label uppercase tabular-nums tracking-theme text-paper shadow-md motion-reduce:transition-none theme-dark:bg-paper-dark theme-dark:text-ink-dark"
                  data-hero-status
                  aria-live="polite"
                >
                  01 / {String(totalImages).padStart(2, "0")}
                </p>
              </div>
            )}
          </div>

          <aside class="flex flex-col gap-4" aria-label="Post mood and source">
            {post.vibeSummary && (
              <p class="post-detail-vibe font-body text-vibe-summary lg:text-vibe-summary-desktop font-normal text-quiet text-pretty transition-colors duration-240 ease-theme motion-reduce:transition-none theme-dark:text-quiet-dark" {...(vibeTransitionName ? { style: `view-transition-name: ${vibeTransitionName};` } : {})}>
                {post.vibeSummary}
              </p>
            )}
            {post.permalink && (
              <a
                href={redditHref(post.permalink)}
                class="btn btn-outline btn-sm self-start border border-ink bg-paper text-ink normal-case transition-colors duration-240 ease-theme motion-reduce:transition-none hover:border-ink hover:bg-ink hover:text-paper focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:border-ink-dark theme-dark:bg-paper-dark theme-dark:text-ink-dark theme-dark:hover:border-ink-dark theme-dark:hover:bg-ink-dark theme-dark:hover:text-paper-dark theme-dark:outline-red-dark"
                target="_blank"
                rel="noopener noreferrer"
              >
                View on Reddit ↗
              </a>
            )}
          </aside>
        </section>
      )}

      {post.tags.length > 0 && (
        <nav class="mb-6" aria-label="Post tags">
          <ul class="scrollbar-hidden flex flex-row flex-nowrap gap-2 overflow-x-auto">
            {post.tags.map(({ tag }) => (
              <li class="shrink-0">
                <a
                  href={tagHref(tag)}
                  class="inline-flex items-center rounded-full border border-ink/40 bg-transparent px-3 py-1 text-label uppercase tracking-theme text-ink transition-colors duration-240 ease-theme motion-reduce:transition-none hover:border-red hover:text-red focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:border-ink-dark/40 theme-dark:text-ink-dark theme-dark:outline-red-dark theme-dark:hover:border-red-dark theme-dark:hover:text-red-dark"
                >{tag}</a>
              </li>
            ))}
          </ul>
        </nav>
      )}

      {post.recommendations.length > 0 && (
        <section aria-label="Recommendations">
          <div class="grid grid-cols-2 gap-4 md:grid-cols-4 md:gap-4">
            {post.recommendations.map((rec, i) => {
              const href = externalHref(rec);
              const isGalleryHero = post.recommendations.length >= 4 && i === 0;
              const isSparseHero = post.recommendations.length === 1 && i === 0;
              const nonHeroCount = post.recommendations.length - 1;
              let trailingSpan = 1;

              // Reserve column four in the first two desktop rows for the
              // feature. Pack cards beneath that reservation in groups of
              // three, then widen the final card to close the partial row.
              if (!isGalleryHero && post.recommendations.length >= 4 && i > 0) {
                if (nonHeroCount < 7 && i === post.recommendations.length - 1) {
                  const remainder = nonHeroCount % 3;
                  trailingSpan = remainder === 1 ? 3 : remainder === 2 ? 2 : 1;
                } else if (nonHeroCount > 6 && i > 6) {
                  const positionAfterFeatureRows = i - 6;
                  const remainingAfterFeatureRows = nonHeroCount - 6;
                  const remainder = remainingAfterFeatureRows % 3;

                  if (positionAfterFeatureRows % 3 === 0) trailingSpan = 2;
                  if (positionAfterFeatureRows === remainingAfterFeatureRows) {
                    trailingSpan = remainder === 1 ? 4 : remainder === 2 ? 3 : 2;
                  }
                }
              }

              const isWide = trailingSpan > 1;
              const trailingSpanClass = trailingSpan === 4
                ? "md:col-span-4"
                : trailingSpan === 3
                  ? "md:col-span-3"
                  : "md:col-span-2";
              const wideDesktopSize = trailingSpan === 4 ? "100vw" : trailingSpan === 3 ? "75vw" : "50vw";
              const isWideArt = isGalleryHero || isSparseHero || isWide;
              const usesBackdrop = !isGalleryHero && isWideArt && !!rec.backdropUrl;
              const imageUrl = usesBackdrop ? rec.backdropUrl : rec.posterUrl;
              const imageSizes = isGalleryHero
                ? "(min-width: 768px) 25vw, 100vw"
                : isSparseHero
                  ? "100vw"
                : isWide
                  ? `(min-width: 768px) ${wideDesktopSize}, 100vw`
                  : "(min-width: 768px) 25vw, 50vw";
              const image = imageUrl
                ? responsiveImage(imageUrl, usesBackdrop ? "backdrop" : "poster", imageSizes)
                : null;
              const cardClass = [
                "group relative block overflow-hidden bg-gallery focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark",
                !isGalleryHero && !isSparseHero && "aspect-poster",
                isGalleryHero && "col-span-2 aspect-recommendation-hero md:col-span-1 md:col-start-4 md:row-start-1 md:row-span-2 md:aspect-auto md:h-full",
                isSparseHero && "col-span-2 aspect-recommendation-hero md:col-span-4",
                isWide && `${trailingSpanClass} md:aspect-auto md:h-full`,
              ].filter(Boolean).join(" ");
              const cardInner = (
                <>
                  <div class="absolute inset-0 bg-gallery transition-colors duration-240 ease-theme motion-reduce:transition-none theme-dark:bg-gallery">
                    {image ? (
                      <img
                        src={image.src}
                        {...(image.srcset ? { srcset: image.srcset } : {})}
                        sizes={image.sizes}
                        alt={rec.title}
                        class:list={[
                          "h-full w-full transition duration-450 ease-gallery motion-reduce:transition-none group-hover:scale-105 group-focus-visible:scale-105",
                          isGalleryHero || usesBackdrop ? "object-cover object-center" : "object-contain",
                        ]}
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <div class="flex h-full w-full items-center justify-center text-no-image text-quiet transition-colors duration-240 ease-theme motion-reduce:transition-none theme-dark:text-quiet-dark">No poster</div>
                    )}
                  </div>
                  <div class="pointer-events-none absolute inset-x-0 bottom-0 flex h-recommendation-overlay flex-col justify-end bg-gradient-to-t from-ink via-ink/70 to-transparent px-3 pb-3 pt-8 text-paper transition-colors duration-240 ease-theme motion-reduce:transition-none">
                    <h3 class="flex items-baseline gap-1 text-base font-semibold leading-tight group-hover:text-red group-focus-visible:text-red theme-dark:group-hover:text-red-dark theme-dark:group-focus-visible:text-red-dark">
                      <span class="min-w-0">{rec.title}</span>
                      {href && (
                        <span class="shrink-0" aria-hidden="true">↗</span>
                      )}
                    </h3>
                    <p class="mt-1 text-xs text-paper/75 theme-dark:text-paper-dark/75">
                      {rec.releaseYear ?? "—"}
                    {rec.voteAverage != null && (
                      <>
                        <span aria-hidden="true"> · </span>
                        <span aria-label={`Rating ${rec.voteAverage.toFixed(1)} out of 10`}>⭐ {rec.voteAverage.toFixed(1)}</span>
                      </>
                    )}
                    </p>
                  </div>
                </>
              );
              return href ? (
                <a
                  href={href}
                  class={cardClass}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${rec.title}${rec.releaseYear ? ` (${rec.releaseYear})` : ""} on ${externalLabel(rec)} (opens in a new tab)`}
                >
                  {cardInner}
                </a>
              ) : (
                <div class={cardClass}>
                  {cardInner}
                </div>
              );
            })}
          </div>
        </section>
      )}

      {hasHero && (
        <dialog id="hero-lightbox" class="modal" aria-label="Image lightbox">
          <div class="modal-box max-w-[min(95vw,1600px)] h-[90vh] w-full bg-paper/0 p-0 shadow-none motion-reduce:transition-none theme-dark:bg-paper-dark/0">
            <form method="dialog" class="absolute right-2 top-2 z-10">
              <button
                type="submit"
                class="btn btn-circle btn-sm border border-ink/20 bg-paper/90 text-ink hover:bg-paper focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 motion-reduce:transition-none theme-dark:border-ink-dark/20 theme-dark:bg-paper-dark/90 theme-dark:text-ink-dark theme-dark:hover:bg-paper-dark theme-dark:outline-red-dark"
                aria-label="Close lightbox"
              >✕</button>
            </form>
            <div
              class="carousel h-full w-full overflow-hidden bg-ink/95 motion-reduce:transition-none theme-dark:bg-ink-dark/95"
              data-modal-carousel
              aria-label={`Image gallery lightbox. ${totalImages} image${totalImages === 1 ? "" : "s"}.`}
            >
              {post.images.map((img, i) => (
                <div id={modalSlideId(i)} class="carousel-item relative h-full w-full">
                  <img
                    src={img.previewUrl ?? img.sourceUrl}
                    alt={`Post image ${i + 1} of ${totalImages}`}
                    class="h-full w-full object-contain"
                    loading={i === 0 ? "eager" : "lazy"}
                    decoding="async"
                  />
                  {totalImages > 1 && (
                    <>
                      <a
                        href={modalPrev(i, totalImages)}
                        class="btn btn-circle absolute left-3 top-1/2 -translate-y-1/2 border border-paper/30 bg-paper/90 text-ink hover:bg-paper focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 motion-reduce:transition-none sm:left-5 theme-dark:border-paper-dark/30 theme-dark:bg-paper-dark/90 theme-dark:text-ink-dark theme-dark:hover:bg-paper-dark theme-dark:outline-red-dark"
                        aria-label="Show previous image"
                      >
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
                          <path d="m15 18-6-6 6-6" />
                        </svg>
                      </a>
                      <a
                        href={modalNext(i, totalImages)}
                        class="btn btn-circle absolute right-3 top-1/2 -translate-y-1/2 border border-paper/30 bg-paper/90 text-ink hover:bg-paper focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 motion-reduce:transition-none sm:right-5 theme-dark:border-paper-dark/30 theme-dark:bg-paper-dark/90 theme-dark:text-ink-dark theme-dark:hover:bg-paper-dark theme-dark:outline-red-dark"
                        aria-label="Show next image"
                      >
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
                          <path d="m9 18 6-6-6-6" />
                        </svg>
                      </a>
                    </>
                  )}
                </div>
              ))}
            </div>
          </div>
          <form method="dialog" class="modal-backdrop">
            <button aria-label="Close lightbox">close</button>
          </form>
        </dialog>
      )}
    </div>
  )}
</Layout>

<style is:global set:html={transitionStyles}></style>

<script>
  const pad = (n: number) => String(n).padStart(2, "0");

  const heroCarousel = document.querySelector<HTMLElement>("[data-hero-carousel]");
  const heroStatus = document.querySelector<HTMLElement>("[data-hero-status]");

  const readHeroSlide = (): number => {
    const hash = window.location.hash;
    const m = hash.match(/#slide(\d+)/);
    return m ? Math.max(1, Math.min(parseInt(m[1], 10), heroCarousel?.querySelectorAll(".carousel-item").length ?? 1)) : 1;
  };

  const renderHeroStatus = () => {
    if (!heroStatus || !heroCarousel) return;
    const total = heroCarousel.querySelectorAll(".carousel-item").length;
    heroStatus.textContent = `${pad(readHeroSlide())} / ${pad(total)}`;
  };

  if (heroCarousel) {
    renderHeroStatus();
    heroCarousel.addEventListener("scroll", () => {
      if (!heroCarousel) return;
      const items = Array.from(heroCarousel.querySelectorAll<HTMLElement>(".carousel-item"));
      if (items.length === 0) return;
      const w = heroCarousel.clientWidth || 1;
      const idx = Math.round(heroCarousel.scrollLeft / w);
      const slideNum = Math.max(1, Math.min(idx + 1, items.length));
      heroStatus && (heroStatus.textContent = `${pad(slideNum)} / ${pad(items.length)}`);
    }, { passive: true });
  }
  window.addEventListener("hashchange", renderHeroStatus);

  const lightbox = document.getElementById("hero-lightbox") as HTMLDialogElement | null;
  const modalCarousel = lightbox?.querySelector<HTMLElement>("[data-modal-carousel]") ?? null;

  document.querySelectorAll<HTMLButtonElement>("[data-open-lightbox]").forEach((button) => {
    button.addEventListener("click", () => {
      if (!lightbox) return;
      lightbox.showModal();
      if (modalCarousel) {
        const idx = parseInt(button.getAttribute("data-open-lightbox") ?? "0", 10);
        const target = modalCarousel.querySelectorAll<HTMLElement>(".carousel-item")[idx];
        if (target) {
          requestAnimationFrame(() => {
            modalCarousel.scrollTo({ left: target.offsetLeft, behavior: "auto" });
          });
        }
      }
    });
  });

  if (lightbox && modalCarousel) {
    lightbox.addEventListener("keydown", (event) => {
      if (event.key !== "ArrowLeft" && event.key !== "ArrowRight") return;
      const items = Array.from(modalCarousel.querySelectorAll<HTMLElement>(".carousel-item"));
      if (items.length === 0) return;
      const w = modalCarousel.clientWidth || 1;
      const currentIdx = Math.min(items.length - 1, Math.max(0, Math.round(modalCarousel.scrollLeft / w)));
      const nextIdx = event.key === "ArrowLeft"
        ? (currentIdx === 0 ? items.length - 1 : currentIdx - 1)
        : (currentIdx === items.length - 1 ? 0 : currentIdx + 1);
      event.preventDefault();
      modalCarousel.scrollTo({ left: items[nextIdx].offsetLeft, behavior: "smooth" });
    });
  }
</script>
</content>
</invoke>
