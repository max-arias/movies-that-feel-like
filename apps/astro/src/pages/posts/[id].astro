---
// Post detail page — shows a single imported vibe post with images, tags, recommendations.

import Layout from "../../layouts/Layout.astro";
import { getPostByRedditId } from "../../lib/db";
import { env } from "cloudflare:workers";

// In server mode, params exist at request time even for non-prerendered fallback
let post: Awaited<ReturnType<typeof getPostByRedditId>>;
try {
  const db = env.DB;
  post = await getPostByRedditId(db, Astro.params.id!);
} catch {
  post = null;
}
---

<Layout title={post ? `${post.title} — Movies That Feel Like` : "Post not found"}>
  {!post ? (
    <div class="hero min-h-64 bg-base-200 rounded-box">
      <div class="hero-content text-center">
        <div class="max-w-md">
          <h2 class="text-xl font-bold">Post not found</h2>
          <p class="py-4 text-base-content/70">
            No post with ID "{Astro.params.id}" was found in the database.
          </p>
          <a href="/" class="btn btn-primary focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark">Back to feed</a>
        </div>
      </div>
    </div>
  ) : (
    <>
      <div class="mb-6">
        <a href="/" class="link link-neutral text-sm focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark">&larr; Back to feed</a>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <div>
          {post.images.length > 0 ? (
            <div
              class="relative overflow-hidden rounded-box bg-base-300 shadow-sm focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark"
              data-gallery
              tabindex="0"
              aria-label={`Image gallery for ${post.title}. Use the previous and next buttons, or the left and right arrow keys.`}
            >
              <div class="relative flex h-detail-gallery items-center justify-center">
                {post.images.map((img, index) => (
                <div
                  class="w-full px-2 sm:px-4"
                  data-gallery-slide
                  data-index={index}
                  aria-hidden={index !== 0 ? "true" : undefined}
                  hidden={index !== 0}
                >
                  <img
                    src={img.url}
                    alt={`Post image ${index + 1} of ${post.images.length}`}
                    class="mx-auto h-full max-h-detail-image w-full object-contain"
                    loading={index === 0 ? "eager" : "lazy"}
                  />
                </div>
                ))}
              </div>

              {post.images.length > 1 && (
                <>
                  <button
                    type="button"
                    class="btn btn-circle btn-sm absolute left-3 top-1/2 -translate-y-1/2 border border-base-content/20 bg-base-100/90 text-base-content shadow-md hover:bg-base-100 focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark sm:left-5 sm:btn-md"
                    data-gallery-previous
                    aria-label="Show previous image"
                  >
                    <svg aria-hidden="true" class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 5.5 8 12l6.5 6.5" /></svg>
                  </button>
                  <button
                    type="button"
                    class="btn btn-circle btn-sm absolute right-3 top-1/2 -translate-y-1/2 border border-base-content/20 bg-base-100/90 text-base-content shadow-md hover:bg-base-100 focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark sm:right-5 sm:btn-md"
                    data-gallery-next
                    aria-label="Show next image"
                  >
                    <svg aria-hidden="true" class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9.5 5.5 6.5 6.5-6.5 6.5" /></svg>
                  </button>
                </>
              )}

              <div class="pointer-events-none absolute inset-x-0 bottom-0 flex justify-center pb-3">
                <p
                  class="rounded-full bg-base-content/80 px-3 py-1 text-xs font-medium text-base-100"
                  data-gallery-status
                  aria-live="polite"
                >
                  1 / {post.images.length}
                </p>
              </div>
            </div>
          ) : (
            <div class="w-full h-64 bg-base-300 rounded-box flex items-center justify-center text-base-content/40">
              No images
            </div>
          )}
        </div>

        <div>
          <h1 class="text-3xl font-bold mb-2">{post.title}</h1>

          {post.vibe_summary && (
            <div class="mb-4 p-4 bg-base-300 rounded-box">
              <p class="text-sm italic text-base-content/80">{post.vibe_summary}</p>
            </div>
          )}

          <div class="flex flex-wrap gap-2 mb-4">
            {post.tags.map((t) => (
              <span class="badge badge-soft badge-outline">{t.tag}</span>
            ))}
          </div>

          {post.selftext && (
            <div class="mb-4">
              <h3 class="font-semibold mb-1">Selftext</h3>
              <p class="text-sm text-base-content/70 whitespace-pre-wrap">{post.selftext}</p>
            </div>
          )}

          <div class="stats stats-vertical sm:stats-horizontal shadow-sm mb-4">
            <div class="stat">
              <div class="stat-title">Author</div>
              <div class="stat-value text-lg">{post.author ?? "unknown"}</div>
            </div>
            <div class="stat">
              <div class="stat-title">Status</div>
              <div class="stat-value text-lg">{post.status}</div>
            </div>
          </div>

          <div class="flex gap-2 mb-6">
            {post.permalink && (
              <a
                href={`https://reddit.com${post.permalink}`}
                class="btn btn-outline btn-sm focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark"
                target="_blank"
              >
                View on Reddit ↗
              </a>
            )}
          </div>

          <div>
            <h2 class="text-xl font-bold mb-3">Recommendations ({post.recommendations.length})</h2>
            {post.recommendations.length === 0 ? (
              <p class="text-sm text-base-content/50">No recommendations extracted yet.</p>
            ) : (
              <div class="grid grid-cols-1 gap-4">
                {post.recommendations.map((rec) => (
                  <div class="card card-side bg-base-300 shadow-sm">
                    {rec.poster_url && (
                      <figure class="w-24 shrink-0">
                        <img
                          src={rec.poster_url}
                          alt={rec.title}
                          class="h-full w-full object-cover"
                          loading="lazy"
                        />
                      </figure>
                    )}
                    <div class="card-body p-4">
                      <div class="flex items-start justify-between gap-2">
                        <a
                          href={`/recommendations/${rec.id}/`}
                          class="card-title text-base hover:link focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark"
                        >
                          {rec.title}
                        </a>
                        <span class="badge badge-soft badge-sm">
                          {rec.media_type === "game" ? "🎮" : rec.media_type === "movie" ? "🎬" : "📺"} {rec.media_type}
                        </span>
                      </div>
                      {rec.release_year && (
                        <p class="text-sm text-base-content/60">{rec.release_year}</p>
                      )}
                      {rec.vote_average && (
                        <p class="text-xs text-base-content/50">
                          ⭐ {rec.vote_average.toFixed(1)}
                        </p>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </>
  )}
</Layout>

<script>
  document.querySelectorAll<HTMLElement>("[data-gallery]").forEach((gallery) => {
    const slides = Array.from(gallery.querySelectorAll<HTMLElement>("[data-gallery-slide]"));
    const previous = gallery.querySelector<HTMLButtonElement>("[data-gallery-previous]");
    const next = gallery.querySelector<HTMLButtonElement>("[data-gallery-next]");
    const status = gallery.querySelector<HTMLElement>("[data-gallery-status]");
    let current = 0;

    const show = (index: number, loop = true) => {
      current = loop
        ? ((index % slides.length) + slides.length) % slides.length
        : Math.max(0, Math.min(index, slides.length - 1));
      slides.forEach((slide, slideIndex) => {
        const active = slideIndex === current;
        slide.hidden = !active;
        slide.setAttribute("aria-hidden", String(!active));
      });
      if (status) status.textContent = `${current + 1} / ${slides.length}`;
    };

    previous?.addEventListener("click", () => show(current - 1));
    next?.addEventListener("click", () => show(current + 1));
    gallery.addEventListener("keydown", (event) => {
      if (event.key === "ArrowLeft") {
        event.preventDefault();
        show(current - 1);
      } else if (event.key === "ArrowRight") {
        event.preventDefault();
        show(current + 1);
      } else if (event.key === "Home") {
        event.preventDefault();
        show(0, false);
      } else if (event.key === "End") {
        event.preventDefault();
        show(slides.length - 1, false);
      }
    });

    show(0);
  });
</script>
