---
// Movies That Feel Like — discovery feed of imported Reddit vibe posts.

import Layout from "../layouts/Layout.astro";
import { getBuildData } from "../lib/build-data";

const { posts } = await getBuildData();

const tagCounts = new Map<string, number>();
for (const post of posts) {
  for (const { tag } of post.tags) tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
}
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
const requestedTag = Astro.url.searchParams.get("tag");
const selectedTag = requestedTag && tags.some(([tag]) => tag === requestedTag) ? requestedTag : "all";
const visiblePosts = selectedTag === "all"
  ? posts
  : posts.filter((post) => post.tags.some(({ tag }) => tag === selectedTag));
const tagHref = (tag: string) => tag === "all"
  ? Astro.url.pathname
  : `${Astro.url.pathname}?tag=${encodeURIComponent(tag)}`;
const maxTagCount = Math.max(1, ...tags.map(([, count]) => count));
---

<Layout
  title="Movies That Feel Like — a visual discovery index"
  description="Discover movies that match the feeling of the stories, places, and moments you love."
>
  {
    posts.length === 0 ? (
      <div class="mb-20 border border-line p-empty transition-colors duration-240 ease-theme motion-reduce:transition-none theme-dark:border-line-dark">
          <h2 class="mb-2.5 font-display text-5xl uppercase">No posts loaded yet</h2>
          <p class="text-error text-quiet theme-dark:text-quiet-dark">
              No publishable posts found in the database.
          </p>
          <p class="text-error text-quiet theme-dark:text-quiet-dark">
              Run the pipeline load stage and <code>npm run seed</code>.
          </p>
      </div>
    ) : (
      <div class="flex flex-col-reverse gap-12 md:index-grid md:grid md:items-start md:gap-index-gap">
        <section class="min-w-0" aria-label="Vibe posts">
          <div class="drawer mobile-filter sticky top-drawer-top z-20 block w-screen mx-full-bleed mt-drawer-overlap mb-drawer-margin bg-paper p-5 theme-dark:bg-paper-dark motion-reduce:transition-none md:hidden">
            <input id="mobile-filter-drawer" type="checkbox" class="drawer-toggle focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark" />
            <div class="drawer-content motion-reduce:transition-none">
              <label for="mobile-filter-drawer" class="flex cursor-pointer items-center justify-between border border-line bg-paper px-filter-x py-filter-y text-filter uppercase transition-colors duration-240 ease-theme focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark theme-dark:border-line-dark theme-dark:bg-paper-dark motion-reduce:transition-none"><span>Filters</span><span class="text-icon font-normal leading-half text-red transition-colors duration-240 ease-theme theme-dark:text-red-dark" aria-hidden="true">＋</span></label>
            </div>
            <div class="drawer-side motion-reduce:transition-none">
              <label for="mobile-filter-drawer" class="drawer-overlay focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark motion-reduce:transition-none" aria-label="Close filters"></label>
              <div class="min-h-full w-drawer-panel bg-paper px-5 py-drawer-panel-y text-ink theme-dark:bg-paper-dark theme-dark:text-ink-dark motion-reduce:transition-none">
                <div class="mb-4 flex items-center justify-between border-b border-line pb-drawer-heading-pad text-filter uppercase transition-colors duration-240 ease-theme theme-dark:border-line-dark motion-reduce:transition-none"><span>Filter by feeling</span><label for="mobile-filter-drawer" class="cursor-pointer p-close text-close font-light text-red transition-colors duration-240 ease-theme focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark theme-dark:text-red-dark motion-reduce:transition-none" aria-label="Close filters">×</label></div>
                <div class="tag-list flex flex-col gap-1.5" data-max-count={maxTagCount} role="group" aria-label="Filter posts by tag">
                  <a class:list={["text-tag-all-mobile flex w-full cursor-pointer items-baseline justify-end gap-tag bg-transparent py-tag-mobile text-right font-display font-extrabold uppercase leading-tag tracking-tag text-quiet transition duration-200 ease-theme motion-reduce:transition-none hover:-translate-x-tag-hover hover:text-red focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark theme-dark:text-quiet-dark theme-dark:hover:text-red-dark", { "text-red theme-dark:text-red-dark -translate-x-tag-hover": selectedTag === "all" }]} href={tagHref("all")} aria-current={selectedTag === "all" ? "page" : undefined}><span class="order-2 min-w-0 wrap-normal">All</span></a>
                  {tags.map(([tag, count]) => <a class:list={["tag-size flex w-full cursor-pointer items-baseline justify-end gap-tag bg-transparent py-tag-mobile text-right font-display font-extrabold uppercase leading-tag tracking-tag text-quiet transition duration-200 ease-theme motion-reduce:transition-none hover:-translate-x-tag-hover hover:text-red focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark theme-dark:text-quiet-dark theme-dark:hover:text-red-dark", { "text-red theme-dark:text-red-dark -translate-x-tag-hover": selectedTag === tag }]} data-count={count} href={tagHref(tag)} aria-current={selectedTag === tag ? "page" : undefined}><b class="order-1 min-w-5 text-right font-body text-count font-medium text-quiet theme-dark:text-quiet-dark">{count}</b><span class="order-2 min-w-0 wrap-normal">{tag}</span></a>)}
                </div>
              </div>
            </div>
          </div>
          <ul class="grid grid-cols-1 gap-mobile-rail-gap md:grid-cols-2 md:gap-rail-gap">
            {visiblePosts.map((post, galleryIndex) => (
              <li class="min-w-0 md:[&:nth-child(even)]:translate-y-rail-offset" data-post-tags={post.tags.map(({ tag }) => tag).join("|")}>
                <article class="pt-post-top">
                    {post.images.length > 0 ? (
                      <div class="relative aspect-square overflow-hidden bg-gallery" data-gallery data-gallery-index={galleryIndex} aria-label={`Image gallery for ${post.title}`}>
                        <a class="group block h-full w-full overflow-hidden focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark" href={`/posts/${post.redditPostId}/`} aria-label={`View details for ${post.title}`}>
                          <div class="gallery-track scrollbar-hidden flex h-full w-full snap-x snap-mandatory overflow-x-auto overflow-y-clip motion-reduce:scroll-auto">
                            {post.images.map((image, imageIndex) => (
                              <img class="block h-full min-h-0 w-full basis-full shrink-0 snap-start object-cover transition duration-450 ease-gallery motion-reduce:transition-none group-hover:scale-105 group-hover:brightness-75 group-focus-visible:scale-105 group-focus-visible:brightness-75" src={image.previewUrl ?? image.sourceUrl} alt={`${post.title} — image ${imageIndex + 1}`} loading={imageIndex === 0 && galleryIndex === 0 ? "eager" : "lazy"} decoding="async" fetchpriority={imageIndex === 0 && galleryIndex === 0 ? "high" : undefined} />
                            ))}
                          </div>
                        </a>
                        <div class="pointer-events-none absolute inset-x-0 bottom-0 h-gallery-overlay bg-gradient-to-b from-transparent to-gallery-overlay"></div>
                        {post.images.length > 1 && <div class="absolute bottom-0 right-0 z-10 flex items-center gap-control bg-paper px-control-x py-control-y text-label transition-colors duration-240 ease-theme motion-reduce:transition-none theme-dark:bg-paper-dark"><button class="cursor-pointer border-0 bg-transparent p-0 text-control text-ink transition-colors duration-240 ease-theme motion-reduce:transition-none focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark theme-dark:text-ink-dark" type="button" data-gallery-previous aria-label="Previous image">←</button><span class="tabular-nums text-quiet transition-colors duration-240 ease-theme motion-reduce:transition-none theme-dark:text-quiet-dark" data-gallery-status>01 / {String(post.images.length).padStart(2, "0")}</span><button class="cursor-pointer border-0 bg-transparent p-0 text-control text-ink transition-colors duration-240 ease-theme motion-reduce:transition-none focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark theme-dark:text-ink-dark" type="button" data-gallery-next aria-label="Next image">→</button></div>}
                      </div>
                    ) : <div class="flex aspect-square items-center justify-center bg-gallery-empty text-no-image text-gallery-empty-text">No image loaded</div>}
                    {post.vibeSummary && (
                      <p class="mt-3 text-body text-quiet transition-colors duration-240 ease-theme motion-reduce:transition-none theme-dark:text-quiet-dark">
                        {post.vibeSummary}
                      </p>
                    )}
                </article>
              </li>
            ))}
          </ul>
        </section>
        <aside class="@container static w-full min-w-0 md:sticky md:top-6" aria-label="Filter by feeling">
          <div class="tag-list tag-mask scrollbar-hidden max-h-sidebar-height hidden flex-col gap-1.5 overflow-y-auto overscroll-contain pt-sidebar-top pb-sidebar-bottom md:flex" data-max-count={maxTagCount} role="group" aria-label="Filter posts by tag">
            <a class:list={["text-tag-all-desktop @2xs:text-tag-all-2xs @xs:text-tag-all-xs flex w-full cursor-pointer items-baseline justify-end gap-tag bg-transparent py-tag text-right font-display font-extrabold uppercase leading-tag tracking-tag text-quiet transition duration-200 ease-theme motion-reduce:transition-none hover:-translate-x-tag-hover hover:text-red focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark theme-dark:text-quiet-dark theme-dark:hover:text-red-dark", { "text-red theme-dark:text-red-dark -translate-x-tag-hover": selectedTag === "all" }]} href={tagHref("all")} aria-current={selectedTag === "all" ? "page" : undefined}><span class="order-2 min-w-0 wrap-normal">All</span></a>
            {tags.map(([tag, count]) => <a class:list={["tag-size flex w-full cursor-pointer items-baseline justify-end gap-tag bg-transparent py-tag text-right font-display font-extrabold uppercase leading-tag tracking-tag text-quiet transition duration-200 ease-theme motion-reduce:transition-none hover:-translate-x-tag-hover hover:text-red focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark theme-dark:text-quiet-dark theme-dark:hover:text-red-dark", { "text-red theme-dark:text-red-dark -translate-x-tag-hover": selectedTag === tag }]} data-count={count} href={tagHref(tag)} aria-current={selectedTag === tag ? "page" : undefined}><b class="order-1 min-w-5 text-right font-body text-count font-medium text-quiet theme-dark:text-quiet-dark">{count}</b><span class="order-2 min-w-0 wrap-normal">{tag}</span></a>)}
          </div>
        </aside>
      </div>
    )
  }
</Layout>

<script>
  const applyTagFilter = () => {
    const requestedTag = new URLSearchParams(window.location.search).get("tag");
    const posts = Array.from(document.querySelectorAll<HTMLElement>("[data-post-tags]"));
    const knownTags = new Set(posts.flatMap((post) => (post.dataset.postTags ?? "").split("|").filter(Boolean)));
    const selectedTag = requestedTag && knownTags.has(requestedTag) ? requestedTag : "all";

    posts.forEach((post) => {
      post.hidden = selectedTag !== "all" && !(post.dataset.postTags ?? "").split("|").includes(selectedTag);
    });
  };

  applyTagFilter();
  document.addEventListener("astro:page-load", applyTagFilter);

  document.querySelectorAll<HTMLElement>("[data-gallery]").forEach((gallery) => {
    const track = gallery.querySelector<HTMLElement>(".gallery-track");
    const slides = Array.from(gallery.querySelectorAll<HTMLImageElement>("img"));
    const status = gallery.querySelector<HTMLElement>("[data-gallery-status]");
    let current = 0;
    const move = (direction: number) => {
      current = (current + direction + slides.length) % slides.length;
      track?.scrollTo({ left: current * (track.clientWidth || 1), behavior: window.matchMedia("(prefers-reduced-motion: reduce)").matches ? "auto" : "smooth" });
      if (status) status.textContent = `${String(current + 1).padStart(2, "0")} / ${String(slides.length).padStart(2, "0")}`;
    };
    gallery.querySelector("[data-gallery-previous]")?.addEventListener("click", () => move(-1));
    gallery.querySelector("[data-gallery-next]")?.addEventListener("click", () => move(1));

  });

</script>
