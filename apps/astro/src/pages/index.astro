---
// Movies That Feel Like — discovery feed of imported Reddit vibe posts.

import Layout from "../layouts/Layout.astro";
import { getPublishedPosts, getPostCount } from "../lib/db";
import { env } from "cloudflare:workers";

const db = env.DB;

let posts: Awaited<ReturnType<typeof getPublishedPosts>> = [];
let postCount = 0;
let dbError: string | undefined;
try {
  postCount = await getPostCount(db);
  posts = await getPublishedPosts(db);
} catch (e) {
  dbError = String(e);
}

const tagCounts = new Map<string, number>();
for (const post of posts) {
  for (const { tag } of post.tags) tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
}
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
const requestedTag = Astro.url.searchParams.get("tag");
const selectedTag = requestedTag && tagCounts.has(requestedTag) ? requestedTag : "all";
const visiblePosts = selectedTag === "all"
  ? posts
  : posts.filter((post) => post.tags.some(({ tag }) => tag === selectedTag));
const tagHref = (tag: string) => tag === "all"
  ? Astro.url.pathname
  : `${Astro.url.pathname}?tag=${encodeURIComponent(tag)}`;
---

<Layout title="Movies That Feel Like — a visual discovery index">
  {
    dbError ? (
      <div class="empty-state">
          <h2>Database error</h2>
          <p class="error-copy">{dbError}</p>
          <p class="muted-copy">
              Make sure the local D1 database is initialized:
              <code class="ml-1">npm run db:migrate</code>
          </p>
      </div>
    ) : posts.length === 0 ? (
      <div class="empty-state">
          <h2>No posts loaded yet</h2>
          <p class="muted-copy">
              No publishable posts found in the database.
          </p>
          <p class="muted-copy">
              Run the pipeline load stage and <code>npm run seed</code>.
          </p>
      </div>
    ) : (
      <div class="index-layout">
        <section class="feed" aria-label="Vibe posts">
          <div class="drawer mobile-filter">
            <input id="mobile-filter-drawer" type="checkbox" class="drawer-toggle" />
            <div class="drawer-content">
              <label for="mobile-filter-drawer" class="filter-trigger">Filters <span aria-hidden="true">＋</span></label>
            </div>
            <div class="drawer-side">
              <label for="mobile-filter-drawer" class="drawer-overlay" aria-label="Close filters"></label>
              <div class="filter-drawer-panel">
                <div class="filter-drawer-heading"><span>Filter by feeling</span><label for="mobile-filter-drawer" aria-label="Close filters">×</label></div>
                <div class="tag-list" role="group" aria-label="Filter posts by tag">
                  <a class:list={["tag-filter", { "is-active": selectedTag === "all" }]} style="--tag-size: 2rem" href={tagHref("all")} aria-current={selectedTag === "all" ? "page" : undefined}><span>All</span></a>
                  {tags.map(([tag, count]) => <a class:list={["tag-filter", { "is-active": selectedTag === tag }]} style={`--tag-size: ${Math.max(1, 1 + (count / Math.max(...tags.map(([, value]) => value))) ** 0.7 * .65)}rem`} href={tagHref(tag)} aria-current={selectedTag === tag ? "page" : undefined}><b>{count}</b><span>{tag}</span></a>)}
                </div>
              </div>
            </div>
          </div>
          <div class="rails">
            {[0, 1].map((rail) => (
              <div class="rail" data-rail={rail}>
                {visiblePosts.filter((_, index) => index % 2 === rail).map((post, index) => (
                  <article class="vibe-post">
                    {post.images.length > 0 ? (
                      <div class="film-gallery carousel" data-gallery aria-label={`Image gallery for ${post.title}`}>
                        <a class="gallery-link" href={`/posts/${post.reddit_post_id}/`} aria-label={`View details for ${post.title}`}>
                          <div class="gallery-track carousel-item">
                            {post.images.map((image, imageIndex) => (
                              <img src={image.url} alt={`${post.title} — image ${imageIndex + 1}`} loading="lazy" />
                            ))}
                          </div>
                        </a>
                        {post.images.length > 1 && <div class="gallery-controls"><button type="button" data-gallery-previous aria-label="Previous image">←</button><span data-gallery-status>01 / {String(post.images.length).padStart(2, "0")}</span><button type="button" data-gallery-next aria-label="Next image">→</button></div>}
                      </div>
                    ) : <div class="no-image">No image loaded</div>}
                    <div class="post-caption">
                      <h2>{post.cleaned_title ?? post.title}</h2>
                      {post.vibe_summary && <p>{post.vibe_summary}</p>}
                    </div>
                  </article>
                ))}
              </div>
            ))}
          </div>
        </section>
        <aside class="tag-index" aria-label="Filter by feeling">
          <div class="desktop-tag-list tag-list" role="group" aria-label="Filter posts by tag">
            <a class:list={["tag-filter", { "is-active": selectedTag === "all" }]} style="--tag-size: 4.8rem" href={tagHref("all")} aria-current={selectedTag === "all" ? "page" : undefined}><span>All</span></a>
            {tags.map(([tag, count]) => <a class:list={["tag-filter", { "is-active": selectedTag === tag }]} style={`--tag-size: ${Math.max(1.1, 1.1 + (count / Math.max(...tags.map(([, value]) => value))) ** 0.7 * 2.8)}rem`} href={tagHref(tag)} aria-current={selectedTag === tag ? "page" : undefined}><b>{count}</b><span>{tag}</span></a>)}
          </div>
        </aside>
      </div>
    )
  }
</Layout>

<style is:global>
  .post-caption h2 {
    overflow-wrap: anywhere;
  }

  @media (max-width: 760px) {
    .feed .mobile-filter {
      margin: -48px calc(50% - 50vw) 18px !important;
      width: 100vw !important;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>("[data-gallery]").forEach((gallery) => {
    const track = gallery.querySelector<HTMLElement>(".gallery-track");
    const slides = Array.from(gallery.querySelectorAll<HTMLImageElement>("img"));
    const status = gallery.querySelector<HTMLElement>("[data-gallery-status]");
    let current = 0;
    const move = (direction: number) => {
      current = (current + direction + slides.length) % slides.length;
      track?.scrollTo({ left: current * (track.clientWidth || 1), behavior: "smooth" });
      if (status) status.textContent = `${String(current + 1).padStart(2, "0")} / ${String(slides.length).padStart(2, "0")}`;
    };
    gallery.querySelector("[data-gallery-previous]")?.addEventListener("click", () => move(-1));
    gallery.querySelector("[data-gallery-next]")?.addEventListener("click", () => move(1));
  });

</script>
