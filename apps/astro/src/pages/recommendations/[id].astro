---
// Recommendation detail page — TMDB-enriched movie/TV info and all posts that recommended it.

import Layout from "../../layouts/Layout.astro";
import {
  getRecommendationById,
  getPostsForRecommendation,
} from "../../lib/db";

const recId = Number(Astro.params.id!);
let rec: Awaited<ReturnType<typeof getRecommendationById>>;
let posts: Awaited<ReturnType<typeof getPostsForRecommendation>>;
try {
  const db = Astro.locals.runtime.env.DB as D1Database;
  rec = await getRecommendationById(db, recId);
  posts = rec ? await getPostsForRecommendation(db, recId) : [];
} catch {
  rec = null;
  posts = [];
}
---

<Layout title={rec ? `${rec.title} — Movies That Feel Like` : "Recommendation not found"}>
  {!rec ? (
    <div class="hero min-h-64 bg-base-200 rounded-box">
      <div class="hero-content text-center">
        <div class="max-w-md">
          <h2 class="text-xl font-bold">Recommendation not found</h2>
          <p class="py-4 text-base-content/70">
            No recommendation with ID "{Astro.params.id}" was found.
          </p>
          <a href="/" class="btn btn-primary">Back to feed</a>
        </div>
      </div>
    </div>
  ) : (
    <>
      <div class="mb-6">
        <a href="/" class="link link-neutral text-sm">&larr; Back to feed</a>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div>
          {rec.poster_url ? (
            <img
              src={rec.poster_url}
              alt={rec.title}
              class="w-full rounded-box shadow-sm"
            />
          ) : (
            <div class="w-full aspect-[2/3] bg-base-300 rounded-box flex items-center justify-center text-base-content/40">
              No poster
            </div>
          )}
        </div>

        <div class="lg:col-span-2">
          <div class="flex items-start gap-3 flex-wrap mb-2">
            <h1 class="text-3xl font-bold">{rec.title}</h1>
            {rec.release_year && (
              <span class="text-2xl text-base-content/50">({rec.release_year})</span>
            )}
          </div>

          <div class="flex flex-wrap gap-2 mb-4">
            <span class="badge badge-soft badge-primary">
              {rec.media_type === "movie" ? "🎬 Movie" : "📺 TV"}
            </span>
            {rec.vote_average && (
              <span class="badge badge-soft badge-accent">
                ⭐ {rec.vote_average.toFixed(1)}
              </span>
            )}
            {rec.popularity && (
              <span class="badge badge-soft badge-outline">Popularity {rec.popularity.toFixed(0)}</span>
            )}
          </div>

          {rec.overview && (
            <div class="mb-6">
              <p class="text-base-content/80 leading-relaxed">{rec.overview}</p>
            </div>
          )}

          <div class="stats stats-vertical shadow-sm mb-6">
            {rec.imdb_id && (
              <div class="stat">
                <div class="stat-title">IMDb</div>
                <div class="stat-value text-lg">
                  <a
                    href={`https://www.imdb.com/title/${rec.imdb_id}/`}
                    class="link link-primary"
                    target="_blank"
                  >
                    {rec.imdb_id} ↗
                  </a>
                </div>
              </div>
            )}
            {rec.tmdb_id && (
              <div class="stat">
                <div class="stat-title">TMDB</div>
                <div class="stat-value text-lg">
                  <a
                    href={`https://www.themoviedb.org/${rec.media_type}/${rec.tmdb_id}`}
                    class="link link-primary"
                    target="_blank"
                  >
                    #{rec.tmdb_id} ↗
                  </a>
                </div>
              </div>
            )}
          </div>

          <div>
            <h2 class="text-xl font-bold mb-3">
              Recommended in {posts.length} post(s)
            </h2>
            {posts.length === 0 ? (
              <p class="text-sm text-base-content/50">No posts found.</p>
            ) : (
              <div class="grid grid-cols-1 gap-3">
                {posts.map((post) => (
                  <div class="card card-side bg-base-300 shadow-sm">
                    <div class="card-body p-4">
                      <a
                        href={`/posts/${post.reddit_post_id}/`}
                        class="card-title text-base hover:link"
                      >
                        {post.title}
                      </a>
                      {post.extracted_text && (
                        <p class="text-sm text-base-content/60">
                          Mentioned as: <span class="italic">"{post.extracted_text}"</span>
                        </p>
                      )}
                      <div class="flex items-center gap-2 mt-1">
                        <span class="text-xs text-base-content/40">
                          by {post.author ?? "unknown"}
                        </span>
                        <span class="badge badge-soft badge-sm badge-outline">{post.status}</span>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </>
  )}
</Layout>
