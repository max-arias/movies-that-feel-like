---
import Layout from "../../layouts/Layout.astro";
import { getDb, getAllRecommendationIds, getRecommendationById, getPostsForRecommendation } from "../../lib/db";
import { env } from "cloudflare:workers";

export async function getStaticPaths() {
  const db = getDb(env);
  const ids = await getAllRecommendationIds(db);
  return Promise.all(ids.map(async ({ id }) => ({
    params: { id: String(id) },
    props: {
      recommendation: await getRecommendationById(db, id),
      posts: await getPostsForRecommendation(db, id),
    },
  })));
}

const { recommendation, posts } = Astro.props;
const externalHref = recommendation?.imdbId
  ? `https://www.imdb.com/title/${recommendation.imdbId}/`
  : recommendation?.tmdbId
    ? `https://www.themoviedb.org/${recommendation.mediaType === "tv" ? "tv" : "movie"}/${recommendation.tmdbId}`
    : recommendation?.externalUrl ?? null;
---
<Layout title={recommendation ? `${recommendation.title} — Movies That Feel Like` : "Recommendation not found"}>
  {recommendation ? (
    <article class="pb-24">
      <section class="grid grid-cols-1 gap-8 md:grid-cols-[minmax(12rem,20rem)_1fr]">
        <div class="aspect-[2/3] bg-gallery">
          {recommendation.posterUrl ? <img src={recommendation.posterUrl} alt={recommendation.title} class="h-full w-full object-cover" /> : <div class="flex h-full items-center justify-center text-quiet">No poster</div>}
        </div>
        <div>
          <h1 class="font-display text-5xl uppercase">{recommendation.title}</h1>
          <p class="mt-3 text-quiet">{recommendation.releaseYear ?? ""}{recommendation.voteAverage != null && ` · ⭐ ${recommendation.voteAverage.toFixed(1)}`}</p>
          {recommendation.overview && <p class="mt-8 max-w-prose text-quiet">{recommendation.overview}</p>}
          {externalHref && <a class="btn btn-outline mt-8" href={externalHref} target="_blank" rel="noopener noreferrer">View external details ↗</a>}
        </div>
      </section>
      <section class="mt-16" aria-label="Posts featuring this recommendation">
        <h2 class="mb-6 font-display text-3xl uppercase">Featured in</h2>
        <div class="grid gap-4 md:grid-cols-2">
          {posts.map((post) => <a class="border border-line p-5 transition-colors hover:border-red" href={`/posts/${post.redditPostId}/`}><h3 class="font-display text-2xl uppercase">{post.title}</h3>{post.vibeSummary && <p class="mt-2 text-quiet">{post.vibeSummary}</p>}</a>)}
        </div>
      </section>
    </article>
  ) : <p>Recommendation not found.</p>}
</Layout>
