---
// Recommendation detail page — TMDB-enriched movie/TV info and all posts that recommended it.

import Layout from "../../layouts/Layout.astro";
import {
  getDb,
  getRecommendationById,
  getPostsForRecommendation,
} from "../../lib/db";
import { env } from "cloudflare:workers";

const recId = Number(Astro.params.id!);
let rec: Awaited<ReturnType<typeof getRecommendationById>> | null;
let posts: Awaited<ReturnType<typeof getPostsForRecommendation>>;
try {
  const db = getDb(env);
  rec = await getRecommendationById(db, recId);
  posts = rec ? await getPostsForRecommendation(db, recId) : [];
} catch {
  rec = null;
  posts = [];
}
---

<Layout title={rec ? `${rec.title} — Movies That Feel Like` : "Recommendation not found"}>
  {!rec ? (
    <div class="hero min-h-64 bg-base-200 rounded-box">
      <div class="hero-content text-center">
        <div class="max-w-md">
          <h2 class="text-xl font-bold">Recommendation not found</h2>
          <p class="py-4 text-base-content/70">
            No recommendation with ID "{Astro.params.id}" was found.
          </p>
          <a href="/" class="btn btn-primary focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark">Back to feed</a>
        </div>
      </div>
    </div>
  ) : (
    <>
      <div class="mb-6">
        <a href="/" class="link link-neutral text-sm focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark">&larr; Back to feed</a>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div>
          {rec.posterUrl ? (
            <img
              src={rec.posterUrl}
              alt={rec.title}
              class="w-full rounded-box shadow-sm"
            />
          ) : (
            <div class="w-full aspect-poster bg-base-300 rounded-box flex items-center justify-center text-base-content/40">
              No poster
            </div>
          )}
        </div>

        <div class="lg:col-span-2">
          <div class="flex items-start gap-3 flex-wrap mb-2">
            <h1 class="text-3xl font-bold">{rec.title}</h1>
            {rec.releaseYear && (
              <span class="text-2xl text-base-content/50">({rec.releaseYear})</span>
            )}
          </div>

          <div class="flex flex-wrap gap-2 mb-4">
            <span class="badge badge-soft badge-primary">
              {rec.mediaType === "game" ? "🎮 Game" : rec.mediaType === "movie" ? "🎬 Movie" : "📺 TV"}
            </span>
            {rec.voteAverage && (
              <span class="badge badge-soft badge-accent">
                ⭐ {rec.voteAverage.toFixed(1)}
              </span>
            )}
            {rec.popularity && (
              <span class="badge badge-soft badge-outline">Popularity {rec.popularity.toFixed(0)}</span>
            )}
          </div>

          {rec.overview && (
            <div class="mb-6">
              <p class="text-base-content/80 leading-relaxed">{rec.overview}</p>
            </div>
          )}

          {rec.mediaType === "game" ? (
            <div class="stats stats-vertical shadow-sm mb-6">
              {rec.igdbId && (
                <div class="stat">
                  <div class="stat-title">IGDB</div>
                  <div class="stat-value text-lg">
                    {rec.externalUrl ? (
                      <a href={rec.externalUrl} class="link link-primary focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark" target="_blank">
                        #{rec.igdbId} ↗
                      </a>
                    ) : (
                      <span>#{rec.igdbId}</span>
                    )}
                  </div>
                </div>
              )}
            </div>
          ) : (
            <div class="stats stats-vertical shadow-sm mb-6">
              {rec.imdbId && (
                <div class="stat">
                  <div class="stat-title">IMDb</div>
                  <div class="stat-value text-lg">
                    <a
                      href={`https://www.imdb.com/title/${rec.imdbId}/`}
                      class="link link-primary focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark"
                      target="_blank"
                    >
                      {rec.imdbId} ↗
                    </a>
                  </div>
                </div>
              )}
              {rec.tmdbId && (
                <div class="stat">
                  <div class="stat-title">TMDB</div>
                  <div class="stat-value text-lg">
                    <a
                      href={`https://www.themoviedb.org/${rec.mediaType}/${rec.tmdbId}`}
                      class="link link-primary focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark"
                      target="_blank"
                    >
                      #{rec.tmdbId} ↗
                    </a>
                  </div>
                </div>
              )}
            </div>
          )}

          {rec.mediaType === "game" && rec.platforms && rec.platforms.length > 0 && (
            <div class="mb-6">
              <h3 class="text-sm font-semibold text-base-content/70 mb-2">Platforms</h3>
              <div class="flex flex-wrap gap-2">
                {rec.platforms.map((p) => (
                  <span class="badge badge-soft badge-outline">{p}</span>
                ))}
              </div>
            </div>
          )}

          <div>
            <h2 class="text-xl font-bold mb-3">
              Recommended in {posts.length} post(s)
            </h2>
            {posts.length === 0 ? (
              <p class="text-sm text-base-content/50">No posts found.</p>
            ) : (
              <div class="grid grid-cols-1 gap-3">
                {posts.map((post) => (
                  <div class="card card-side bg-base-300 shadow-sm">
                    <div class="card-body p-4">
                      <a
                        href={`/posts/${post.redditPostId}/`}
                        class="card-title text-base hover:link focus-visible:outline-2 focus-visible:outline-red focus-visible:outline-offset-4 theme-dark:outline-red-dark"
                      >
                        {post.title}
                      </a>
                      {post.extractedText && (
                        <p class="text-sm text-base-content/60">
                          Mentioned as: <span class="italic">"{post.extractedText}"</span>
                        </p>
                      )}
                      <div class="flex items-center gap-2 mt-1">
                        <span class="text-xs text-base-content/40">
                          by {post.author ?? "unknown"}
                        </span>
                        <span class="badge badge-soft badge-sm badge-outline">{post.status}</span>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </>
  )}
</Layout>
